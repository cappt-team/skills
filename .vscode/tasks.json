{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "cappt: build (current platform)",
      "type": "shell",
      "command": "make build",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": "$go"
    },
    {
      "label": "cappt: build all platforms",
      "type": "shell",
      "command": "make build-all",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": "$go"
    },
    {
      "label": "cappt: package",
      "type": "shell",
      "command": "make package",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "cappt: clean",
      "type": "shell",
      "command": "make clean",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "setup: init symlinks (run once)",
      "type": "shell",
      "command": "mkdir -p ${userHome}/.local/bin && ln -sf ${workspaceFolder}/dist/cappt ${userHome}/.local/bin/cappt && ln -sf ${workspaceFolder}/skills/cappt ${userHome}/.claude/skills/cappt && echo 'Symlinks created.'",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "none",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}
